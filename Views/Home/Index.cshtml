@{
    ViewData["Title"] = "Home Page";
}

<div class="container mt-5">
    <h2 class="mb-4">📊 Аналіз складів</h2>

    <div class="row mb-4">
        <div class="col-md-6">
            <label for="warehouseSelect" class="form-label">Оберіть склад:</label>
            <div class="input-group">
                <select id="warehouseSelect" class="form-select">
                    <option value="1">Склад 1 (Київ)</option>
                    <option value="2">Склад 2 (Львів)</option>
                    <option value="3">Склад 3 (Одеса)</option>
                    <option value="4">Склад 4 (Харків)</option>
                </select>
                <button id="btnStart" class="btn btn-primary" onclick="startAutoRefresh()">▶ Аналіз</button>
                <button id="btnStop" class="btn btn-danger d-none" onclick="stopAutoRefresh()">⏹ Зупинити</button>
            </div>
        </div>
        <div class="col-md-6 d-flex align-items-end">
            <div id="statusBar" class="d-none w-100">
                <span class="badge bg-success" id="statusBadge">●</span>
                <span id="statusText" class="text-muted small"></span>
                <span id="countdown" class="fw-bold small"></span>
                <span id="lastUpdated" class="float-end text-muted small"></span>
            </div>
        </div>
    </div>

    <!-- Продукти на складі -->
    <div class="row mb-4">
        <div class="col-md-5">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    🏭 Продукти на складі: <span id="warehouseName">—</span>
                </div>
                <div class="card-body p-0">
                    <table class="table table-striped table-hover mb-0">
                        <thead>
                            <tr><th>Продукт</th><th>Кількість</th><th>Од.</th></tr>
                        </thead>
                        <tbody id="stockTable">
                            <tr><td colspan="3" class="text-center text-muted">Очікування...</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Розподіл по точках -->
        <div class="col-md-7">
            <div class="card">
                <div class="card-header bg-success text-white">
                    🚚 Розподіл ресурсів по точках доставки
                </div>
                <div class="card-body p-0">
                    <table class="table table-striped table-hover mb-0">
                        <thead>
                            <tr><th>Точка</th><th>Потрібно</th><th>Виділено</th><th>Пріоритет</th><th>Статус</th></tr>
                        </thead>
                        <tbody id="distributionTable">
                            <tr><td colspan="5" class="text-center text-muted">Очікування...</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- Залишок -->
    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card text-center" id="remainingCard">
                <div class="card-body">
                    <h6 class="text-muted">Залишок на складі</h6>
                    <h2 id="remainingStock" class="mb-0">—</h2>
                </div>
            </div>
        </div>
    </div>

    <!-- AI консоль -->
    <div class="card bg-black border-secondary">
        <div class="card-header text-secondary border-secondary">🤖 AI аналіз</div>
        <div class="card-body p-0">
            <pre id="outputConsole"
                 style="color: #00ff00; background: #000; padding: 20px; margin: 0; min-height: 150px; white-space: pre-wrap; font-family: 'Consolas', monospace;">Натисніть "Аналіз" для запуску...</pre>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const REFRESH_INTERVAL = 5000;
        let refreshTimer = null;
        let countdownTimer = null;
        let isRunning = false;

        async function fetchWarehouseData() {
            const id = document.getElementById('warehouseSelect').value;
            const statusText = document.getElementById('statusText');
            const statusBadge = document.getElementById('statusBadge');

            try {
                statusBadge.className = 'badge bg-warning';
                statusBadge.textContent = '⏳';
                statusText.textContent = 'Завантаження...';

                // 1) Структуровані дані
                const summaryResp = await fetch(`/api/ai/warehouse-summary/${id}`);
                const data = await summaryResp.json();
                renderSummary(data);

                // 2) AI пояснення
                const aiResp = await fetch(`/api/ai/run-test/${id}`);
                const aiText = await aiResp.text();
                document.getElementById('outputConsole').innerText = aiText;

                const now = new Date().toLocaleTimeString('uk-UA');
                document.getElementById('lastUpdated').textContent = `Оновлено: ${now}`;
                statusBadge.className = 'badge bg-success';
                statusBadge.textContent = '●';
                statusText.textContent = 'Оновлено. Наступне через ';
            } catch (err) {
                statusBadge.className = 'badge bg-danger';
                statusBadge.textContent = '✕';
                statusText.textContent = 'Помилка. Повтор через ';
                document.getElementById('outputConsole').innerText = 'Помилка: ' + err.message;
            }

            startCountdown();
        }

        function renderSummary(data) {
            document.getElementById('warehouseName').textContent = data.warehouse;

            // Таблиця продуктів на складі
            const stockTbody = document.getElementById('stockTable');
            if (data.stock.length === 0) {
                stockTbody.innerHTML = '<tr><td colspan="3" class="text-center text-warning">Склад порожній</td></tr>';
            } else {
                stockTbody.innerHTML = data.stock.map(s => `
                    <tr>
                        <td>${s.product}</td>
                        <td><strong>${s.quantity}</strong></td>
                        <td>${s.unit}</td>
                    </tr>`).join('');
            }

            // Таблиця розподілу
            const distTbody = document.getElementById('distributionTable');
            if (data.distribution.length === 0) {
                distTbody.innerHTML = '<tr><td colspan="5" class="text-center text-warning">Немає попиту</td></tr>';
            } else {
                distTbody.innerHTML = data.distribution.map(d => {
                    const pct = d.required > 0 ? Math.round(d.allocated / d.required * 100) : 0;
                    const badgeClass = pct >= 100 ? 'bg-success' : pct >= 50 ? 'bg-warning' : 'bg-danger';
                    return `
                    <tr>
                        <td>${d.point} <small class="text-muted">#${d.pointId}</small></td>
                        <td>${d.required}</td>
                        <td><strong>${d.allocated}</strong></td>
                        <td>${d.priority}</td>
                        <td>
                            <div class="progress" style="min-width:80px">
                                <div class="progress-bar ${badgeClass}" style="width:${pct}%">${pct}%</div>
                            </div>
                        </td>
                    </tr>`;
                }).join('');
            }

            // Залишок
            const remaining = data.remaining;
            const remEl = document.getElementById('remainingStock');
            const remCard = document.getElementById('remainingCard');
            remEl.textContent = remaining;
            remCard.className = remaining > 0
                ? 'card text-center border-success'
                : 'card text-center border-danger';
        }

        function startCountdown() {
            const countdownEl = document.getElementById('countdown');
            let seconds = REFRESH_INTERVAL / 1000;
            clearInterval(countdownTimer);
            countdownTimer = setInterval(() => {
                seconds--;
                if (seconds > 0) {
                    countdownEl.textContent = `${seconds} с`;
                } else {
                    countdownEl.textContent = '';
                    clearInterval(countdownTimer);
                }
            }, 1000);
        }

        function startAutoRefresh() {
            if (isRunning) return;
            isRunning = true;

            document.getElementById('btnStart').classList.add('d-none');
            document.getElementById('btnStop').classList.remove('d-none');
            document.getElementById('statusBar').classList.remove('d-none');
            document.getElementById('warehouseSelect').disabled = true;

            fetchWarehouseData();
            refreshTimer = setInterval(fetchWarehouseData, REFRESH_INTERVAL);
        }

        function stopAutoRefresh() {
            isRunning = false;
            clearInterval(refreshTimer);
            clearInterval(countdownTimer);
            refreshTimer = null;

            document.getElementById('btnStart').classList.remove('d-none');
            document.getElementById('btnStop').classList.add('d-none');
            document.getElementById('statusBar').classList.add('d-none');
            document.getElementById('warehouseSelect').disabled = false;
            document.getElementById('countdown').textContent = '';
            document.getElementById('statusText').textContent = '';
        }
    </script>
}