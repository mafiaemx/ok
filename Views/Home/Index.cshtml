@{
    ViewData["Title"] = "Home Page";
}

<div class="container mt-5">
    <h2 class="mb-4">Аналіз складів</h2>
    <div class="row mb-4">
        <div class="col-md-4">
            <label for="warehouseSelect" class="form-label">Оберіть склад із списку:</label>
            <div class="input-group">
                <select id="warehouseSelect" class="form-select">
                    <option value="1">Склад 1 (Київ)</option>
                    <option value="2">Склад 2 (Львів)</option>
                </select>
                <button class="btn btn-primary" onclick="checkSelectedWarehouse()">Перевірити</button>
            </div>
        </div>
    </div>

    <div class="card bg-black border-secondary">
        <div class="card-header text-secondary border-secondary">Результат запиту</div>
        <div class="card-body p-0">
            <pre id="outputConsole"
                 style="color: #00ff00; background: #000; padding: 20px; margin: 0; min-height: 250px; white-space: pre-wrap; font-family: 'Consolas', monospace;"></pre>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        async function checkSelectedWarehouse() {
            const id = document.getElementById('warehouseSelect').value;
            const output = document.getElementById('outputConsole');
            const response = await fetch(`/api/ai/run-test/${id}`);
            const text = await response.text();
            output.innerText = text;
}
    </script>
}